#!/bin/bash
# One-command full refresh + deploy script
#
# Recommended usage (after adding alias):
#   push                    # uses default message
#   push "your message"     # custom commit message
#
# To enable just typing "push":
#   Add this to your ~/.bashrc or ~/.zshrc:
#     alias push='./push'
#   Then run: source ~/.bashrc   (or ~/.zshrc)
#
# You can also run it directly with: ./push "message"

echo "🔄 Refreshing data..."
python3 update_coffee.py || { echo "⚠️  update_coffee.py had issues (continuing anyway)"; }

echo "🔨 Building..."
npm run build

echo "📤 Committing and pushing..."
git add .
git commit -m "${1:-Update dashboard}" || true
git push

echo ""
echo "✅ Done! The GitHub Action is deploying the latest version."
echo "   Elon on X and Roasts are now manual (high-signal, correct direct links)."
echo "   Live site: https://robbittsaunders.github.io/coffee/"
echo "   Check Actions tab for the deploy status."